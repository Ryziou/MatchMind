# AI
GEMINI_API_KEY=your_key_here
OPENAI_API_KEY=

# ChromaDB
# Use "chroma" with docker compose. Use "localhost" when running the server via npm.
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Server
PORT=3001
NODE_ENV=development

# RAG tuning (optional overrides)
RAG_TOP_K=8
MAX_UPLOAD_MB=5
GEMINI_GENERATION_MODEL=gemini-2.5-flash
OPENAI_GENERATION_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
CHAT_HISTORY_TURNS=6
# Default provider when the client does not send one
AI_PROVIDER=gemini
# LOG_LEVEL=info
