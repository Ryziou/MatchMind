# AI
GEMINI_API_KEY=your_key_here

# ChromaDB
# Use "chroma" with docker compose. Use "localhost" when running the server via npm.
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Server
PORT=3001
NODE_ENV=development

# RAG tuning (optional overrides)
RAG_TOP_K=8
MAX_UPLOAD_MB=5
GEMINI_GENERATION_MODEL=gemini-2.5-flash
